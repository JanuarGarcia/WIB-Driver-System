{
  "name": "wib-rider-dashboard",
  "version": "1.0.0",
  "description": "Node.js Rider assignment dashboard - uses WIB Rider Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently -n api,vite \"node server.js\" \"npm run dev:client\"",
    "build": "cd client && npm install && npm run build",
    "dev:client": "cd client && npm run dev"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
