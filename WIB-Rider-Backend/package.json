{
  "name": "wib-rider-backend",
  "version": "1.0.0",
  "description": "Node.js backend for WIB Driver App - driver API, admin dashboard, MySQL, FCM push",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node -r dotenv/config server.js",
    "init-db": "node -r dotenv/config scripts/init-db.js",
    "migrate-driver-photos": "node -r dotenv/config scripts/migrate-driver-task-photos.js",
    "migrate-driver-client-id": "node -r dotenv/config scripts/add-mt-driver-client-id.js",
    "migrate-client-password-bcrypt": "node -r dotenv/config scripts/add-client-password-bcrypt-column.js",
    "migrate-mt-driver-password-bcrypt": "node -r dotenv/config scripts/add-mt-driver-password-bcrypt-column.js",
    "smoke-driver-login": "node -r dotenv/config scripts/smoke-driver-login.js",
    "debug-login-db": "node -r dotenv/config scripts/debug-driver-login-db.js",
    "test": "jest"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^30.0.5"
  }
}
