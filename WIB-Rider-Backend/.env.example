# Server
PORT=3000

# MySQL – use either "Local" or "Live server" below, then copy this file to .env and set values
#
# Production / staging — driver login + dashboard must share one logical DB:
#   Set DB_HOST, DB_USER, DB_PASSWORD, DB_NAME to the same MySQL database that holds mt_driver rows
#   the WIB-Rider-Dashboard lists (often the same schema as mt_admin_user / food ordering tables).

# --- Local ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
# Database name. Use wibdb if mt_admin_user (dashboard login) lives there; use wib_driver for driver/tasks only.
DB_NAME=wibdb
# Primary DB pool size (default 10). Secondary pools (MercifulGod / ErrandWib) default to 5 each — see DB_AUX_POOL_CONNECTION_LIMIT.
# DB_POOL_CONNECTION_LIMIT=10
# DB_AUX_POOL_CONNECTION_LIMIT=5
# Max queued acquires when pool is busy (default 80). Use 0 only if you accept unlimited queueing / hung HTTP requests.
# DB_POOL_QUEUE_LIMIT=80
# DB_CONNECT_TIMEOUT_MS=20000
# On startup, the API creates (if missing) mt_dashboard_rider_notification and mt_dashboard_notification_dedupe
# on this database — dashboard bell inbox only; the driver app still uses mt_driver_pushlog.

# --- Centralized dual-database reads (optional; same host/user as DB_* unless overridden) ---
# Existing features keep using DB_NAME via config/db.js `pool`.
# Named pools for separate schemas (no cross-DB SQL joins — merge in Node when needed):
# DB_MERCIFULGOD_NAME=wheninba_MercifulGod
# DB_ERRANDWIB_NAME=wheninba_ErrandWib
# DB_MERCIFULGOD_HOST=
# DB_MERCIFULGOD_USER=
# DB_MERCIFULGOD_PASSWORD=
# DB_ERRANDWIB_HOST=
# DB_ERRANDWIB_USER=
# DB_ERRANDWIB_PASSWORD=

# --- Live server (uncomment and set to use production database) ---
# DB_HOST=your-live-mysql-host.com
# DB_PORT=3306
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_NAME=wib_driver

# API Hash Key — fallback when mt_option has no driver_api_hash_key row.
# validateApiKey (middleware/auth.js) loads mt_option.driver_api_hash_key first; if that row exists,
# the rider app api_key must match that value (env API_HASH_KEY alone is not enough).
API_HASH_KEY=GodissoGood@33

# Rider Flutter: FCM device registry on this same server (api_key + session token as /driver/api).
# POST /api/riders/devices/register and /api/riders/devices/unregister — see sql/wib_rider_device_and_push.sql.
# If the app’s API_BASE_URL is not this host, configure the Flutter app with RIDER_PUSH_API_BASE_URL = this origin (no trailing slash).

# Public base URL for the driver Flutter app JSON API (optional). When set, POST /driver/api/GetAppSettings
# includes "mobile_api_url" normalized to …/driver/api. Must be the same logical API + DB as this server
# (see docs/DRIVER_LOGIN_UNIFIED_ACCOUNTS.md). When unset, GetAppSettings omits mobile_api_url and the app uses its default base.
# MOBILE_API_URL=https://your-public-host.com/driver/api

# Driver Login: optional st_client lookup on errand DB (only if mt_driver.client_id references st_client.client_id)
# DRIVER_LOGIN_CHECK_ERRAND_ST_CLIENT=0
# DRIVER_LOGIN_RATE_WINDOW_MS=900000
# DRIVER_LOGIN_RATE_MAX=40

# Rider uses mt_driver: after legacy password match, write bcrypt to mt_driver.password_bcrypt only (not mt_client).
# AUTO_FILL_RIDER_PASSWORD_BCRYPT=1
# (legacy alias) AUTO_FILL_CLIENT_PASSWORD_BCRYPT=1
# Production: keep off so rider login never uses mt_client / findRiderClientAcrossDatabases (routes/driver.js).
# Optional: login by mt_client email + mt_driver.client_id — set to 1 only for unified customer→driver accounts.
DRIVER_LOGIN_MT_CLIENT_FALLBACK=0
# Temporary: log DB name + body key names when mt_driver login lookup finds no row (set to 0 in production after fixing).
# DRIVER_LOGIN_DEBUG=1
# Same DB as API: npm run debug-login-db -- test123
# Legacy: replace mt_driver.password with bcrypt on every login (breaks old rider app). Default off.
# MT_DRIVER_LOGIN_UPGRADE_PASSWORD_COLUMN=0

# Rider app version compatibility gate (default: keep backward compatibility on)
# When 1, backend does not block older app versions. Keep this on while Play Store rollout is pending.
# RIDER_APP_FORCE_COMPATIBILITY=1
# Minimum allowed Rider app version once enforcement starts (example: 2.6.0)
# RIDER_APP_MIN_SUPPORTED_VERSION=
# Start date/time for min version policy (ISO 8601, UTC/local accepted by Node Date parser)
# RIDER_APP_MIN_SUPPORTED_ENFORCE_AFTER=
# Additional grace days after ENFORCE_AFTER so riders who cannot auto-update can still use old app
# RIDER_APP_VERSION_GRACE_DAYS=14
# If old app does not send app_version, allow request during compatibility/grace windows
# RIDER_APP_ALLOW_UNKNOWN_VERSION=1

# Firebase Admin SDK (path to service account JSON for driverapp-8bf94)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Optional: Android notification channel id for customer FCM (must match the customer app’s channel).
# Improves heads-up / tray delivery on Android 8+ when the app defines a non-default channel.
# FCM_CUSTOMER_ANDROID_CHANNEL_ID=high_importance_channel

# Optional: base URL for profile photo links (e.g. http://localhost:3000)
BASE_URL=http://localhost:3000

# Where on disk this API reads/writes uploads (profiles, certs, merchant logos, …). Must match app.js /uploads static root.
# Default: <repo>/WIB-Rider-Backend/uploads. The repo .gitignore ignores uploads/ — production must copy files here or set these paths.
# UPLOADS_DIR=/var/www/wib-rider-api/uploads
# Optional override when merchant logos live outside uploads/merchants (same basename rules as default folder).
# MERCHANT_LOGOS_DIR=/var/www/wib-rider-api/uploads/merchants

# Dashboard proxy / server-to-server (Yii PHP legacy → POST /admin/api/internal/notify-task-status)
# Must match WIB-Rider-Dashboard BACKEND_URL proxy x-admin-key forwarding.
ADMIN_SECRET=

# Customer app API — after a food task is assigned (mt_driver_task), rider backend POSTs dispatch-order (same as ops).
# Never expose PUSH_DISPATCH_SECRET to mobile apps; server-to-server only.
# CUSTOMER_API_BASE_URL=https://your-customer-api-host
# (alias) WIBEATS_API_BASE_URL=https://your-customer-api-host
# PUSH_DISPATCH_SECRET=must-match-customer-backend-.env

# Sync mt_order.status from mt_driver_task milestones:
# acknowledged -> Acknowledge, started -> Started, inprogress -> Inprogress, successful|delivered|completed -> Successful
# MT_ORDER_STATUS_ACKNOWLEDGED=Acknowledge
# MT_ORDER_STATUS_STARTED=Started
# MT_ORDER_STATUS_INPROGRESS=Inprogress
# MT_ORDER_STATUS_SUCCESSFUL=Successful
# Backward-compatible alias for final successful value:
# MT_ORDER_DELIVERED_STATUS=Successful

# Proof-of-delivery image URLs (task details / timeline). When the old app still uploads to another host:
# PROOF_ASSET_BASE_URL=https://wheninbaguioeat.com
# PROOF_LEGACY_PLAIN_USES_DRIVER_PATH=1
# — hotlinks mt_driver_task_photo filenames to https://wheninbaguioeat.com/upload/driver/<file>
# Omit PROOF_ASSET_BASE_URL to serve proofs from this server (BASE_URL + /upload/...).
# photo_name may also be a full https:// URL; that is returned as-is.

# One-time: npm run migrate-driver-photos — download legacy /upload/driver/* files into uploads/driver/
# OLD_PHOTO_BASE_URL=https://wheninbaguioeat.com
# DRY_RUN=1
# LIMIT=50
