# WIB Rider Dashboard – copy to .env and adjust
#
# Backend URL = WIB-Rider-Backend (Express) origin ONLY — no /admin/api path.
# Examples:
#   Local:                    http://localhost:3000
#   Same VPS as dashboard:    http://127.0.0.1:3000
#   Public API subdomain:     https://your-api-host.example.com
# Wrong values cause “API returned a web page instead of JSON” (cPanel HTML, dashboard domain, etc.).
BACKEND_URL=http://localhost:3000
# Optional: same as ADMIN_SECRET in WIB Rider Backend for admin API auth
ADMIN_SECRET=
# Dashboard port (default 3002; use if 3001 is already in use)
DASHBOARD_PORT=3002
# Axios timeout (ms) for proxied GET /api/* — raise if /settings or map data is slow (default 90000)
# DASHBOARD_API_PROXY_TIMEOUT_MS=90000
# Optional: absolute path (or path relative to server.js) to the Vite build folder that contains index.html
# (use if you cannot use client/dist — e.g. DASHBOARD_CLIENT_DIST=./dist)
# DASHBOARD_CLIENT_DIST=
